APP_NAME=Edu Code Platform API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=edu_user
MYSQL_PASSWORD=edu_password
MYSQL_DB=edu_code_platform
JWT_SECRET_KEY=please-change-this-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
CODE_RUN_TIMEOUT_SECONDS=15
CODE_RUN_MAX_OUTPUT_CHARS=20000
CODE_RUN_TEMP_DIR=/tmp/edu_code_runner
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*
CORS_ALLOW_CREDENTIALS=false
